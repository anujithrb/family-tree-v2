{
  "name": "family-tree-v2",
  "private": true,
  "scripts": {
    "api": "pnpm --filter @family-tree/api run start:dev",
    "admin": "pnpm --filter @family-tree/admin run start:dev",
    "db:generate": "pnpm --filter @family-tree/database run generate",
    "db:migrate": "pnpm --filter @family-tree/database run migrate",
    "db:seed": "pnpm --filter @family-tree/database run seed",
    "db:studio": "pnpm --filter @family-tree/database run studio",
    "test": "pnpm -r run test",
    "build": "pnpm -r run build",
    "web-user": "pnpm --filter @family-tree/web-user exec ng serve",
    "web-user:build": "pnpm --filter @family-tree/web-user exec ng build",
    "web-user:test": "pnpm --filter @family-tree/web-user exec ng test --no-watch",
    "web-admin": "pnpm --filter @family-tree/web-admin exec ng serve",
    "web-admin:build": "pnpm --filter @family-tree/web-admin exec ng build",
    "web-admin:test": "pnpm --filter @family-tree/web-admin exec ng test --no-watch",
    "shared-ui:test": "pnpm --filter @family-tree/shared-ui run test",
    "format": "prettier --write \"apps/web-user/**/*.{ts,html,scss,json}\" \"apps/web-admin/**/*.{ts,html,scss,json}\" \"packages/shared-ui/**/*.{ts,scss,json}\"",
    "format:check": "prettier --check \"apps/web-user/**/*.{ts,html,scss,json}\" \"apps/web-admin/**/*.{ts,html,scss,json}\" \"packages/shared-ui/**/*.{ts,scss,json}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "stylelint": "stylelint \"apps/web-user/**/*.scss\" \"apps/web-admin/**/*.scss\" \"packages/shared-ui/**/*.scss\"",
    "stylelint:fix": "stylelint --fix \"apps/web-user/**/*.scss\" \"apps/web-admin/**/*.scss\" \"packages/shared-ui/**/*.scss\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/web-user/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "apps/web-admin/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "packages/shared-ui/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{html,json,md}": [
      "prettier --write"
    ],
    "**/*.scss": [
      "stylelint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "stylelint": "^17.6.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "typescript-eslint": "^8.58.0"
  }
}
