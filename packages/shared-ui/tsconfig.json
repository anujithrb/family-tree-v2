{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "es2022",
    "moduleResolution": "bundler",
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "types": ["vitest/globals"],
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "services/**/*.ts",
    "tree-viewer/**/*.ts",
    "detail-panel/**/*.ts",
    "wizard/**/*.ts",
    "vitest.config.ts"
  ]
}
